# ==========================================
# 图书管理系统 - 环境变量配置
# ==========================================
# 使用方式：
#   1. cp .env.example .env
#   2. 用随机密钥替换下面的 JWT_SECRET 和 COOKIE_SECRET：
#        JWT_SECRET=$(openssl rand -base64 32)
#        COOKIE_SECRET=$(openssl rand -base64 32)
#   3. 按需修改其他配置
# ==========================================

# MySQL 数据库连接（Docker 部署用 mysql 作为主机名）
MYSQL_DSN=root:123456@tcp(mysql:3306)/library?charset=utf8mb4&parseTime=True&loc=Local

# JWT 签名密钥（必改！不要用示例值）
# 生成命令：openssl rand -base64 32
JWT_SECRET=你的随机密钥

# Session 加密密钥（必改！不要用示例值）
# 生成命令：openssl rand -base64 32
COOKIE_SECRET=你的随机密钥

# 邮箱配置（可选，用于发送注册验证码和密码重置）
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_USER=你的QQ邮箱
SMTP_PASS=你的QQ邮箱授权码
